---
/**
 * Manifesto — 宣言区
 *
 * 编排叙事与文案同构：
 *   第一幕 · 囚 — 3px 墨线沿四边依次画出一个"聊天框"粗线框，前两行宣言在框内升起，
 *              光标在句尾闪烁——大模型被困住的样子。
 *   第二幕 · 破 — 四条粗边框向四个方向炸出屏幕，被困的两行退淡，
 *              「Numen 给他一个身体。」垫草绿色块、以更大的尺度落地；
 *              同一时刻，世界（游戏实录全景）第一次在粗边框相框里显影。
 *   第三幕 · 随 — 竖排「言出法随」在右缘逐字浮现并缓慢上移（视差），
 *              正文两句先后升起收束。
 *
 * 整段 pin 住，由 scrub 驱动；只动 transform / opacity
 * （唯一特例：世界显影允许动 clip-path——缝隙式遮罩揭幕）。
 */
import { Image } from 'astro:assets';
import world from '../assets/landscape-caves-cliffs-mountains.png';
---

<section class="manifesto" id="manifesto">
	<div class="world" aria-hidden="true">
		<div class="world-frame">
			<Image src={world} alt="" class="world-img" widths={[1280, 1920, 2560]} sizes="100vw" loading="lazy" />
		</div>
	</div>
	<div class="glyph-rail" aria-hidden="true">
		<span class="glyph-col">
			<span class="glyph">言</span><span class="glyph">出</span><span class="glyph">法</span><span class="glyph">随</span>
		</span>
	</div>

	<div class="inner">
		<p class="eyebrow">Numen</p>

		<h2 class="statement">
			<span class="cage">
				<span class="cage-edge edge-t" aria-hidden="true"></span>
				<span class="cage-edge edge-r" aria-hidden="true"></span>
				<span class="cage-edge edge-b" aria-hidden="true"></span>
				<span class="cage-edge edge-l" aria-hidden="true"></span>
				<span class="line-mask"><span class="line l1">大模型不该，</span></span>
				<span class="line-mask"
					><span class="line l2"
						>困在聊天框里。<span class="caret" aria-hidden="true"><span class="caret-bar"></span></span></span
					></span
				>
			</span>
			<span class="line-mask free-mask"><span class="line l3">Numen 给他一个身体。</span></span>
		</h2>

		<p class="lede">
			<span class="lede-a"
				>一个遵守游戏规则的真实假玩家：会感知地形，会查询配方，会规划路线；会挖矿、建造、战斗、看家。</span
			>
			<span class="lede-b">你说一句话，他便在这个世界里真实地发生。</span>
		</p>
	</div>
</section>

<style>
	.manifesto {
		--cream: #fef9ed;
		--ink: #171310;
		--moss: #86c15c;
		--muted: color-mix(in srgb, var(--ink) 62%, transparent);
		--faint: color-mix(in srgb, var(--ink) 44%, transparent);
		--font-cjk:
			'Source Han Sans SC', 'Noto Sans SC', 'PingFang SC', 'Microsoft YaHei',
			sans-serif;
		--font-mono: 'Cascadia Mono', 'SF Mono', Consolas, ui-monospace, monospace;

		position: relative;
		height: 100vh;
		display: flex;
		align-items: center;
		overflow: hidden;
		background-color: var(--cream);
		color: var(--ink);
		font-family: var(--font-cjk);
	}

	/* ---------- 世界显影（破笼时刻的游戏实录，装进粗边框相框） ---------- */
	/* 固定 84vh 高：始终卡在一屏内，不跟随内容高度撑出屏外 */
	.world {
		position: absolute;
		top: 8vh;
		left: 4vw;
		right: 4vw;
		height: 84vh;
		z-index: 0;
		opacity: 0;
		will-change: clip-path, opacity;
		pointer-events: none;
	}

	/* 相框本体：4px ink 边框 + 10px 硬阴影 + 圆角，右/下各留 10px 给阴影 */
	.world-frame {
		position: absolute;
		inset: 0 10px 10px 0;
		border: 4px solid var(--ink);
		border-radius: 10px;
		box-shadow: 10px 10px 0 var(--ink);
		overflow: hidden;
	}

	.world :global(.world-img) {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		will-change: transform;
	}

	/* 一丝米白薄纱：仅给左侧文字兜极浅一点底，不糊灰——画面尽量直给 */
	.world-frame::after {
		content: '';
		position: absolute;
		inset: 0;
		background: rgba(254, 249, 237, 0.04);
	}

	.inner {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 1560px;
		margin-inline: auto;
		padding: 6vh 6vw;
	}

	/* ---------- 眉题 ---------- */
	.eyebrow {
		display: flex;
		align-items: center;
		gap: 1.2rem;
		font-family: var(--font-mono);
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.35em;
		text-transform: uppercase;
		color: var(--muted);
		margin-bottom: clamp(3rem, 7vh, 5rem);
	}

	.eyebrow::before {
		content: '';
		width: 2.5rem;
		height: 3px;
		background: currentColor;
	}

	/* ---------- 宣言 ---------- */
	.statement {
		position: relative;
		font-weight: 900;
		letter-spacing: 0.01em;
		margin: 0;
	}

	.line-mask {
		display: block;
		overflow: hidden;
	}

	.line {
		display: block;
		will-change: transform;
	}

	/* 聊天框（囚笼）：绝对定位，不占布局高度——它注定要飞走，
	   于是 l3 与正文能自然收进一屏；与 l3 同锚在 statement 顶 */
	.cage {
		position: absolute;
		top: 0;
		left: 0;
		display: inline-block;
		padding: clamp(2rem, 4.5vh, 3.4rem) clamp(2.2rem, 4vw, 4rem);
	}

	.cage .line {
		font-size: clamp(2.2rem, 5.2vw, 5rem);
		line-height: 1.32;
	}

	.cage-edge {
		position: absolute;
		background: var(--ink);
		will-change: transform, opacity;
	}

	.edge-t { top: 0; left: 0; right: 0; height: 3px; transform-origin: left center; }
	.edge-r { top: 0; right: 0; bottom: 0; width: 3px; transform-origin: center top; }
	.edge-b { bottom: 0; left: 0; right: 0; height: 3px; transform-origin: right center; }
	.edge-l { top: 0; left: 0; bottom: 0; width: 3px; transform-origin: center bottom; }

	/* 框内光标：被困者的心跳 */
	.caret {
		display: inline-block;
		vertical-align: baseline;
		margin-left: 0.2em;
	}

	.caret-bar {
		display: inline-block;
		width: 0.06em;
		min-width: 3px;
		height: 0.85em;
		background: currentColor;
	}

	@media (prefers-reduced-motion: no-preference) {
		.caret-bar {
			animation: blink 1.1s steps(1, end) infinite;
		}
	}

	@keyframes blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}

	/* 第三行：出笼，更大，ink 字垫草绿色块（3px 边框实体签）。
	   与 cage 同锚在 statement 顶——笼子飞走、这行升起，落在原地 */
	.free-mask {
		margin-top: 0;
	}

	.l3 {
		display: inline-block;
		font-size: clamp(2.7rem, 7vw, 6.9rem);
		line-height: 1.18;
		color: var(--ink);
		background-color: var(--moss);
		border: 3px solid var(--ink);
		border-radius: 10px;
		padding: 0.06em 0.32em 0.1em;
	}

	/* ---------- 正文 ---------- */
	.lede {
		margin: clamp(2.8rem, 7vh, 4.5rem) 0 0;
		max-width: 36em;
		font-size: clamp(1.05rem, 1.6vw, 1.35rem);
		line-height: 2;
	}

	.lede span {
		display: block;
		will-change: transform;
	}

	.lede-a {
		color: var(--muted);
	}

	.lede-b {
		color: var(--ink);
		font-weight: 700;
		margin-top: 1.1em;
	}

	/* ---------- 竖排铭文：言出法随（米白 + 墨黑硬阴影，压在深图上跳出来） ---------- */
	.glyph-rail {
		position: absolute;
		inset-block: 0;
		right: clamp(1.5rem, 5vw, 6rem);
		display: flex;
		align-items: center;
		pointer-events: none;
		user-select: none;
	}

	.glyph-col {
		writing-mode: vertical-rl;
		font-weight: 900;
		font-size: clamp(6.5rem, 19vh, 16rem);
		line-height: 1;
		letter-spacing: 0.08em;
		color: var(--cream);
		opacity: 0.88;
		text-shadow: 5px 5px 0 var(--ink);
		will-change: transform;
	}

	.glyph {
		display: inline-block;
		will-change: transform, opacity;
	}

	/* ---------- 响应式 ---------- */
	@media (max-width: 768px) {
		.inner {
			padding-block: 14vh;
		}

		.world {
			inset: 6vh 4vw;
		}

		.cage {
			padding: clamp(1.4rem, 3vh, 2rem) clamp(1.2rem, 5vw, 2rem);
		}

		.cage .line {
			font-size: clamp(1.7rem, 7.2vw, 2.4rem);
		}

		.l3 {
			font-size: clamp(2.1rem, 9.4vw, 3.2rem);
		}

		.glyph-col {
			font-size: 11vh;
		}

		.glyph-rail {
			right: 3vw;
		}
	}
</style>

<script>
	import { gsap } from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
		gsap.registerPlugin(ScrollTrigger);

		const section = document.getElementById('manifesto');
		if (section) {
			const q = gsap.utils.selector(section);

			const tl = gsap.timeline({
				defaults: { ease: 'power2.out' },
				scrollTrigger: {
					trigger: section,
					start: 'top top',
					/* 拉长滚程：同一段动画摊在更多滚动里，每帧位移更小 → 更顺，不再卡顿感 */
					end: '+=175%',
					pin: true,
					/* 更大的平滑：scrub 追赶更柔和 */
					scrub: 1,
					anticipatePin: 1,
				},
			});

			/* ============ 第一幕 · 囚 ============
			   粗墨线绕四边一笔画出聊天框，前两行在框内升起 */
			tl.from(q('.eyebrow'), { autoAlpha: 0, y: 22, duration: 0.8 }, 0)
				.from(q('.edge-t'), { scaleX: 0, duration: 0.55, ease: 'power1.inOut' }, 0.15)
				.from(q('.edge-r'), { scaleY: 0, duration: 0.55, ease: 'power1.inOut' }, 0.62)
				.from(q('.edge-b'), { scaleX: 0, duration: 0.55, ease: 'power1.inOut' }, 1.09)
				.from(q('.edge-l'), { scaleY: 0, duration: 0.55, ease: 'power1.inOut' }, 1.56)
				.from(q('.l1'), { yPercent: 112, duration: 0.9 }, 1.35)
				.from(q('.l2'), { yPercent: 112, duration: 0.9 }, 2.0);

			/* —— 2.9 → 3.6：静场一拍，让"困"停留 —— */

			/* ============ 第二幕 · 破 ============
			   四条边向四个方向弹射出屏，旧宣言退暗，第三行以身体落地 */
			tl.to(q('.caret'), { autoAlpha: 0, duration: 0.25 }, 3.6)
				.to(q('.edge-t'), { y: '-46vh', autoAlpha: 0, duration: 0.9, ease: 'power2.in' }, 3.6)
				.to(q('.edge-b'), { y: '46vh', autoAlpha: 0, duration: 0.9, ease: 'power2.in' }, 3.68)
				.to(q('.edge-l'), { x: '-46vw', autoAlpha: 0, duration: 0.9, ease: 'power2.in' }, 3.76)
				.to(q('.edge-r'), { x: '46vw', autoAlpha: 0, duration: 0.9, ease: 'power2.in' }, 3.84)
				/* 被困的两行：彻底退场（上移 + 淡出到 0），不留半透明残影挡路 */
				.to(q('.cage'), { autoAlpha: 0, y: '-8vh', duration: 0.7, ease: 'power2.in' }, 3.9)
				.from(q('.l3'), { yPercent: 112, duration: 1.1 }, 4.15)
				.to(q('.inner'), { y: '-3vh', duration: 1.8, ease: 'power1.out' }, 4.15)
				/* 世界显影 · 裂缝揭幕：
				   笼壁炸飞的瞬间（3.72，紧跟 edge-t 起飞）先裂开一线——裂缝里透出世界；
				   l3 落地时（4.1）缝隙自中线向上下全幅揭开（expo.out 落位定格），
				   内层图 1.24→1.06 反向收缩，像镜头从裂缝里退出来对上焦 */
				.fromTo(
					q('.world'),
					{ clipPath: 'inset(50% 0% 50% 0%)', autoAlpha: 0.55 },
					{ clipPath: 'inset(46% 0% 46% 0%)', autoAlpha: 0.66, duration: 0.3, ease: 'power2.out' },
					3.72
				)
				.to(q('.world'), { clipPath: 'inset(0% 0% 0% 0%)', autoAlpha: 1, duration: 1.85, ease: 'power2.out' }, 4.1)
				.fromTo(q('.world-img'), { scale: 1.12 }, { scale: 1.0, duration: 2.1, ease: 'power2.out' }, 3.72)
				/* 显影之后不许静止：极缓慢的呼吸漂移（ease none），幅度极小 */
				.to(q('.world-img'), { scale: 1.02, yPercent: -0.6, duration: 1.85, ease: 'none' }, 5.65);

			/* ============ 第三幕 · 随 ============
			   竖排「言出法随」逐字自右浮现并全程缓慢上移，正文两句收束 */
			tl.to(q('.glyph-col'), { yPercent: -14, duration: 3.6, ease: 'none' }, 3.9)
				.from(q('.glyph'), { autoAlpha: 0, x: 56, duration: 1.1, stagger: 0.22 }, 4.35)
				.from(q('.lede-a'), { autoAlpha: 0, y: 26, duration: 0.9 }, 5.35)
				.from(q('.lede-b'), { autoAlpha: 0, y: 26, duration: 0.9 }, 5.75);

			/* 收尾静场：解 pin 前留极短一拍，避免尾部空滚 */
			tl.to({}, { duration: 0.3 });
		}
	}
</script>
