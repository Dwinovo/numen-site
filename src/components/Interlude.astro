---
// Interlude — 实录过场（粗新野主义皮肤）
// 演示与数字之间的一次呼吸：开窗式显影。
// 米白幕布上立着一只粗边框大相框（4px ink 边框 + 硬偏移阴影）；
// 进场时相框里只有一条横向条幅（一道取景缝），
// 钉住后随滚动向上下扩张填满整个相框；内层实录反向缩放（1.45 → 1），
// 像镜头从特写缓缓拉开——外框在开、里面的世界在退，双向对拉出纵深。
// 全开之后平色蒙版显影，caption 才以贴纸姿态从遮罩里逐字升起。
import { Image } from 'astro:assets';
import scene from '../assets/island-landscape.png';
---

<section class="interlude" aria-label="游戏实录">
	<div class="scene">
		<Image src={scene} alt="Minecraft 海岛全景实录画面" class="scene-img" widths={[1280, 1920, 2560]} sizes="100vw" loading="lazy" />
	</div>
	<span class="scene-frame" aria-hidden="true"></span>
	<span class="frame-edge edge-top" aria-hidden="true"></span>
	<span class="frame-edge edge-bottom" aria-hidden="true"></span>
	<div class="scrim" aria-hidden="true"></div>
	<p class="caption">
		<span class="mask"><span class="caption-eyebrow">实录 · 主世界</span></span>
		<span class="caption-line" aria-label="它已经住进了这个世界。">
			<span class="line-mask" aria-hidden="true"><span class="ch">它</span><span class="ch">已</span><span class="ch">经</span><span class="ch">住</span><span class="ch">进</span><span class="ch">了</span><span class="ch">这</span><span class="ch">个</span><span class="ch">世</span><span class="ch">界</span><span class="ch">。</span></span>
		</span>
	</p>
</section>

<style>
	.interlude {
		--ink: #171310;
		--cream: #fef9ed;
		--tangerine: #f5a623;
		/* 相框在幕布上的留白：上下 10vh、左右 6vw。
		   clip-path 的 35% 以相框自身盒（80vh 高）为参照 = 28vh */
		--frame-y: 10vh;
		--frame-x: 6vw;
		--font-cjk:
			'Source Han Sans SC', 'Noto Sans SC', 'PingFang SC',
			'Microsoft YaHei', 'Hiragino Sans GB', sans-serif;
		--font-mono: 'Cascadia Mono', 'SF Mono', Consolas, ui-monospace, monospace;

		position: relative;
		height: 100vh;
		overflow: hidden;
		background-color: var(--cream); /* 全站统一米白幕布 */
		color: var(--ink);
		font-family: var(--font-cjk);
	}

	/* 取景窗：相框内芯，开窗由脚本用 clip-path 驱动（唯一特例）。
	   无脚本 / reduce 时不带任何裁切——静态即一整幅装裱好的相框图 */
	.scene {
		position: absolute;
		inset: var(--frame-y) var(--frame-x);
		border-radius: 12px;
		overflow: hidden;
		will-change: clip-path;
	}

	.scene :global(.scene-img) {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		will-change: transform;
	}

	/* 大相框本体：不参与裁切，边框与硬阴影全程立在纸面上，
	   开窗动画在框内进行 */
	.scene-frame {
		position: absolute;
		inset: var(--frame-y) var(--frame-x);
		border: 4px solid var(--ink);
		border-radius: 12px;
		box-shadow: 10px 10px 0 var(--ink);
		pointer-events: none;
	}

	/* 条幅上下沿的 3px ink 粗线：跟着窗口边缘走，全开时熄灭。
	   默认不可见——只属于动效，静态版不需要它 */
	.frame-edge {
		position: absolute;
		left: var(--frame-x);
		right: var(--frame-x);
		height: 3px;
		background-color: var(--ink);
		opacity: 0;
		pointer-events: none;
		will-change: transform, opacity;
	}

	.edge-top {
		top: var(--frame-y);
	}

	.edge-bottom {
		bottom: var(--frame-y);
	}

	/* 蒙版：只罩相框内芯的一层平色 ink 薄纱（禁渐变），
	   给贴纸 caption 略压一压画面。静态版常显；动效版在全开后才显影 */
	.scrim {
		position: absolute;
		inset: var(--frame-y) var(--frame-x);
		border-radius: 12px;
		background-color: rgba(23, 19, 16, 0.18);
		pointer-events: none;
		will-change: opacity;
	}

	/* caption 像两张贴纸斜斜拍在相框左下角，跨过框边 */
	.caption {
		position: absolute;
		left: 6vw;
		bottom: 8vh;
		z-index: 1;
		color: var(--ink);
		margin: 0;
	}

	/* 遮罩：文字从各自的窗口里升起，而不是整块淡入 */
	.mask,
	.line-mask {
		display: block;
		overflow: hidden;
	}

	/* 贴纸的旋转放在遮罩层上，升起过程不切角；右下留白给硬阴影 */
	.mask {
		rotate: -2deg;
		padding: 0 8px 8px 0;
		margin-bottom: 1.1rem;
	}

	.caption-eyebrow {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.35em;
		text-transform: uppercase;
		color: var(--ink);
		background-color: var(--tangerine);
		border: 3px solid var(--ink);
		border-radius: 8px;
		box-shadow: 4px 4px 0 var(--ink);
		padding: 0.5em 0.55em 0.45em 0.9em;
		will-change: transform;
	}

	.caption-line {
		display: block;
		font-weight: 900;
		font-size: clamp(1.7rem, 3.6vw, 3.2rem);
		line-height: 1.3;
		rotate: 0.8deg;
	}

	/* 逐字米白垫块：整行连成一条马克笔式高亮条，字随遮罩逐个升起 */
	.caption-line .ch {
		display: inline-block;
		background-color: var(--cream);
		will-change: transform;
	}

	.caption-line .ch:first-child {
		padding-left: 0.14em;
		border-radius: 6px 0 0 6px;
	}

	.caption-line .ch:last-child {
		padding-right: 0.14em;
		border-radius: 0 6px 6px 0;
	}
</style>

<script>
	import { gsap } from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
		gsap.registerPlugin(ScrollTrigger);

		const section = document.querySelector('.interlude');
		if (section) {
			const q = gsap.utils.selector(section as HTMLElement);

			// 进入视口时条幅与粗边线已就位（fromTo 立即渲染），钉住前就能看见那道缝
			gsap.set(q('.frame-edge'), { autoAlpha: 1 });

			// 一次呼吸 = 一条被钉住的 scrub 时间轴：
			// 0 → 6   开窗。clip 从条幅扩到填满相框，内层图 1.45 → 1 反向回退，
			//         上下粗边线贴着窗沿走，抵框后熄灭——镜头拉开，世界变大
			// 4.8 → 6.4 平色蒙版显影，为贴纸 caption 铺底
			// 6.1 → 9.3 caption 编排：眉题贴纸先从遮罩升起，正句十一个字逐字跟上
			// 9.3 → 10.4 留一拍空滚动，让画面在解钉前站稳
			const tl = gsap.timeline({
				defaults: { ease: 'none' },
				scrollTrigger: {
					trigger: section,
					start: 'top top',
					end: '+=160%',
					pin: true,
					scrub: 0.5,
					anticipatePin: 1,
				},
			});

			tl.fromTo(
				q('.scene'),
				{ clipPath: 'inset(35% 0% 35% 0%)' },
				{ clipPath: 'inset(0% 0% 0% 0%)', duration: 6, ease: 'power1.inOut' },
				0
			)
				.fromTo(q('.edge-top'), { y: '28vh' }, { y: '0vh', duration: 6, ease: 'power1.inOut' }, 0)
				.fromTo(q('.edge-bottom'), { y: '-28vh' }, { y: '0vh', duration: 6, ease: 'power1.inOut' }, 0)
				.to(q('.frame-edge'), { autoAlpha: 0, duration: 0.9 }, 5.1);

			// 反向缩放贯穿全程：开窗期退得快，全开后仍在极缓落定——镜头一直是活的
			tl.fromTo(q('.scene-img'), { scale: 1.45 }, { scale: 1, duration: 10, ease: 'power1.out' }, 0);

			tl.fromTo(q('.scrim'), { autoAlpha: 0 }, { autoAlpha: 1, duration: 1.6 }, 4.8);

			tl.fromTo(
				q('.caption-eyebrow'),
				{ yPercent: 150 },
				{ yPercent: 0, duration: 1.2, ease: 'power3.out' },
				6.1
			).fromTo(
				q('.caption-line .ch'),
				{ yPercent: 115 },
				{ yPercent: 0, duration: 1.3, ease: 'power3.out', stagger: 0.12 },
				6.8
			);

			tl.to({}, { duration: 1.1 }, 9.3);
		}
	}
</script>
