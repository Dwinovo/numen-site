---
// 一枚链接 chip：识别平台给品牌色 + 图标 + ↗（外站）。GitHub 用 octocat，其余用品牌色方块。
import { resolvePlatform } from '../lib/links';

const { href, label } = Astro.props as { href: string; label?: string };
const p = resolvePlatform(href);
const text = label && label.trim() ? label : p.label;
---

<a class="plink" href={href} target="_blank" rel="noopener" data-key={p.key} style={`--brand:${p.color}`}>
	{
		p.key === 'github' ? (
			<svg class="plink-gh" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
				<path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.87-.01-1.71-2.78.62-3.37-1.37-3.37-1.37-.46-1.18-1.11-1.5-1.11-1.5-.9-.63.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.05 0-1.12.39-2.03 1.03-2.74-.1-.26-.45-1.3.1-2.7 0 0 .84-.28 2.75 1.05a9.3 9.3 0 0 1 2.5-.34c.85 0 1.71.12 2.5.34 1.91-1.33 2.75-1.05 2.75-1.05.55 1.4.2 2.44.1 2.7.64.71 1.03 1.62 1.03 2.74 0 3.92-2.34 4.78-4.57 5.04.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.6.69.49A10.02 10.02 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z" />
			</svg>
		) : (
			<span class="plink-chip" />
		)
	}
	<span class="plink-label">{text}</span>
	<span class="plink-arrow" aria-hidden="true">↗</span>
</a>

<style>
	.plink {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		font-family: var(--font-mono, ui-monospace, monospace);
		font-size: 0.78rem;
		font-weight: 700;
		color: var(--ink, #171310);
		text-decoration: none;
		border: 2px solid var(--ink, #171310);
		border-radius: 8px;
		box-shadow: 3px 3px 0 var(--ink, #171310);
		background: #fff;
		padding: 0.34em 0.6em;
		transition: transform 0.13s ease, box-shadow 0.13s ease;
	}

	.plink:hover,
	.plink:focus-visible {
		transform: translate(-2px, -2px);
		box-shadow: 5px 5px 0 var(--ink, #171310);
	}

	.plink:active {
		transform: translate(2px, 2px);
		box-shadow: 1px 1px 0 var(--ink, #171310);
	}

	.plink-gh {
		display: block;
		color: var(--brand);
	}

	.plink-chip {
		width: 0.95rem;
		height: 0.95rem;
		border-radius: 4px;
		background: var(--brand);
		border: 2px solid var(--ink, #171310);
		transform: rotate(-4deg);
	}

	.plink-arrow {
		color: color-mix(in srgb, var(--ink, #171310) 42%, transparent);
	}
</style>
