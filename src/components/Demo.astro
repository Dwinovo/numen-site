---
// Demo — 言出法随 · 实录
// 全站签名区块：一段真实对话，随滚动逐拍上演。
// 编排分四幕：你说（逐字成句）→ 它应 → 它做（工具链读出条 + 矿下实录显影）→ 它成（焦点回收到结果）。
import { Image } from 'astro:assets';
import footage from '../assets/cave-mineshaft.png';
---

<section class="demo" id="demo">
	<div class="footage" aria-hidden="true">
		<Image src={footage} alt="" class="footage-img" widths={[1280, 1920, 2560]} sizes="100vw" loading="lazy" />
	</div>
	<div class="demo-inner">
		<p class="demo-eyebrow">言出法随 · 实录</p>

		<div class="chat" role="figure" aria-label="与 Numen 的一段真实对话">
			<!-- 第一幕：你说出口 -->
			<div class="msg from-you" data-msg="you">
				<span class="who">你</span>
				<p class="text" aria-label="帮我搞一组铁来。">
					<span class="typed" aria-hidden="true"><span class="ch">帮</span><span class="ch">我</span><span class="ch">搞</span><span class="ch">一</span><span class="ch">组</span><span class="ch">铁</span><span class="ch">来</span><span class="ch">。</span></span><span class="caret" aria-hidden="true"></span>
				</p>
			</div>

			<!-- 第二幕：它应答 -->
			<div class="msg from-numen" data-msg="ack">
				<span class="who">Numen</span>
				<p class="text">这就去。先下矿找铁。</p>
			</div>

			<!-- 第三幕：它执行（机器读出条） -->
			<div class="msg toolchain" data-msg="tool">
				<code class="tc" aria-label="4 步 · locate_biome · move_to · auto_mine · collect_items ✓"><span class="tc-part tc-count" aria-hidden="true">4 步</span><span class="tc-part tc-step" aria-hidden="true"> · locate_biome</span><span class="tc-part tc-step" aria-hidden="true"> · move_to</span><span class="tc-part tc-step" aria-hidden="true"> · auto_mine</span><span class="tc-part tc-step" aria-hidden="true"> · collect_items</span><span class="tc-part tc-done" aria-hidden="true"> ✓</span></code>
				<span class="tc-progress" aria-hidden="true"></span>
			</div>

			<!-- 第四幕：它办成了 -->
			<div class="msg from-numen msg-final" data-msg="done">
				<span class="who">Numen</span>
				<p class="text">拿到 64 个粗铁——要顺手帮你熔了吗？</p>
			</div>
		</div>

		<p class="demo-note">不是脚本。每一步都是它自己感知、规划、执行的结果。</p>
	</div>
</section>

<style>
	.demo {
		--void: #0e0c0a;
		--cream: #fef9ed;
		--moss: #86c15c;
		--hairline: color-mix(in srgb, currentColor 14%, transparent);
		--muted: color-mix(in srgb, currentColor 58%, transparent);
		--faint: color-mix(in srgb, currentColor 36%, transparent);
		--font-cjk:
			'Source Han Sans SC', 'Noto Sans SC', 'PingFang SC',
			'Microsoft YaHei', 'Hiragino Sans GB', sans-serif;
		--font-mono: 'Cascadia Mono', 'SF Mono', Consolas, ui-monospace, monospace;

		position: relative;
		min-height: 100vh;
		display: flex;
		align-items: center;
		overflow: hidden;
		padding: clamp(6rem, 14vh, 10rem) 6vw;
		background-color: var(--void);
		color: var(--cream);
		font-family: var(--font-cjk);
	}

	/* 矿下实录：执行阶段才显影的背景信号，完成时随焦点回收退场 */
	.footage {
		position: absolute;
		inset: 0;
		z-index: 0;
		opacity: 0;
		will-change: clip-path, opacity;
		pointer-events: none;
	}

	.footage :global(.footage-img) {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		will-change: transform;
	}

	.footage::after {
		content: '';
		position: absolute;
		inset: 0;
		background: rgba(14, 12, 10, 0.82);
	}

	/* 舞台：一根 880px 的窄列居中，四周全是黑，像聚光灯下的一段记录 */
	.demo-inner {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 880px;
		margin-inline: auto;
	}

	.demo-eyebrow {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		letter-spacing: 0.35em;
		text-transform: uppercase;
		color: var(--faint);
		margin-bottom: clamp(3.5rem, 9vh, 6rem);
	}

	.chat {
		display: flex;
		flex-direction: column;
		gap: clamp(2.2rem, 5vh, 3.4rem);
	}

	/* 消息不做气泡——只用排版：小字署名 + 大字正文 + 一根竖向发丝线 */
	.msg {
		width: fit-content;
		max-width: 86%;
	}

	.msg .who {
		display: block;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.28em;
		text-transform: uppercase;
		color: var(--faint);
		margin-bottom: 0.85rem;
	}

	.msg .text {
		font-size: clamp(1.35rem, 2.6vw, 2.1rem);
		font-weight: 500;
		line-height: 1.65;
		letter-spacing: 0.01em;
	}

	.from-you {
		align-self: flex-start;
		border-left: 1px solid var(--hairline);
		padding-left: clamp(1.3rem, 2.6vw, 2rem);
	}

	.from-numen {
		align-self: flex-end;
		border-left: 2px solid var(--moss);
		padding-left: clamp(1.3rem, 2.6vw, 2rem);
	}

	.from-numen .who {
		color: var(--moss);
	}

	.typed .ch {
		display: inline-block;
	}

	/* 打字光标：一枚实心块，只在成句期间点亮 */
	.caret {
		display: inline-block;
		width: 0.52em;
		height: 1.05em;
		margin-left: 0.14em;
		vertical-align: -0.12em;
		background-color: currentColor;
		opacity: 0;
	}

	/* 工具链：横贯整列的机器读出条——上下发丝线夹一行等宽字，
	   底边一根苔绿进度线随执行推进 */
	.toolchain {
		position: relative;
		align-self: stretch;
		width: 100%;
		max-width: 100%;
		margin-block: clamp(0.6rem, 2vh, 1.4rem);
		padding-block: clamp(1.1rem, 2.4vh, 1.6rem);
		border-top: 1px solid var(--hairline);
		border-bottom: 1px solid var(--hairline);
	}

	.tc {
		display: block;
		font-family: var(--font-mono);
		font-size: clamp(0.82rem, 1.35vw, 1.05rem);
		letter-spacing: 0.05em;
		line-height: 1.9;
		color: var(--muted);
		white-space: normal;
		overflow-wrap: break-word;
	}

	.tc-part {
		display: inline-block;
	}

	.tc-count {
		color: var(--cream);
	}

	.tc-step {
		color: var(--cream);
	}

	.tc-done {
		color: var(--moss);
		font-weight: 700;
	}

	.tc-progress {
		position: absolute;
		left: 0;
		bottom: -1px;
		width: 100%;
		height: 1px;
		background-color: var(--moss);
		transform: scaleX(0);
		transform-origin: left center;
	}

	.demo-note {
		margin-top: clamp(4.5rem, 11vh, 7rem);
		font-size: clamp(0.95rem, 1.4vw, 1.2rem);
		line-height: 1.9;
		color: var(--faint);
	}

	@media (max-width: 640px) {
		.demo {
			padding-inline: 7vw;
		}

		.msg {
			max-width: 100%;
		}

		.msg .text {
			font-size: clamp(1.2rem, 5.4vw, 1.5rem);
		}

		.tc {
			font-size: 0.76rem;
			letter-spacing: 0.03em;
		}
	}
</style>

<script>
	import { gsap } from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
		gsap.registerPlugin(ScrollTrigger);

		const section = document.getElementById('demo');
		if (section) {
			const q = gsap.utils.selector(section);

			const eyebrow = q('.demo-eyebrow');
			const msgYou = q('[data-msg="you"]');
			const chars = q('.typed .ch');
			const caret = q('.caret');
			const msgAck = q('[data-msg="ack"]');
			const tool = q('[data-msg="tool"]');
			const tcSteps = q('.tc-step');
			const tcDone = q('.tc-done');
			const tcProgress = q('.tc-progress');
			const msgDone = q('[data-msg="done"]');
			const note = q('.demo-note');

			// 一条被滚动驱动的时间轴：钉住整屏，节奏 = 说 → 应 → 做 → 成 → 注脚
			const tl = gsap.timeline({
				defaults: { ease: 'power2.out' },
				scrollTrigger: {
					trigger: section,
					start: 'top top',
					end: '+=320%',
					pin: true,
					scrub: 0.6,
					anticipatePin: 1,
				},
			});

			// —— 序幕：eyebrow ——
			tl.from(eyebrow, { autoAlpha: 0, y: 24, duration: 0.5 }, 0);

			// —— 第一幕：你说出口。骨架先立，随后逐字成句，光标亮起又熄灭 ——
			tl.from(msgYou, { autoAlpha: 0, y: 36, duration: 0.5 }, 0.4)
				.fromTo(caret, { autoAlpha: 0 }, { autoAlpha: 1, duration: 0.1, ease: 'none' }, 0.62)
				.from(chars, { autoAlpha: 0, duration: 0.12, ease: 'none', stagger: 0.14 }, 0.72)
				.to(caret, { autoAlpha: 0, duration: 0.25, ease: 'none' }, 2.1);

			// —— 第二幕：它应答（停一拍再来，像真的在想）——
			tl.from(msgAck, { autoAlpha: 0, y: 44, duration: 0.7 }, 2.7);

			// —— 第三幕：它执行。读出条落位，四步逐一点亮、随即退灰，
			//    底部苔绿进度线匀速推进，末端 ✓ 弹出定音；
			//    同时矿下实录在背景显影——它真的下矿了 ——
			tl.from(tool, { autoAlpha: 0, y: 30, duration: 0.5 }, 3.8)
				/* 信号接通：矿下实录自中缝横向扫开（clip-path 左右向）——
				   像带宽被拉开、信号铺满全屏，而不是灯被调亮；
				   内层图 1.22→1.07 反向收缩落位（expo.out），揭开即对焦 */
				.fromTo(
					q('.footage'),
					{ clipPath: 'inset(0% 50% 0% 50%)', autoAlpha: 0.55 },
					{ clipPath: 'inset(0% 0% 0% 0%)', autoAlpha: 1, duration: 1.35, ease: 'expo.out' },
					3.95
				)
				.fromTo(q('.footage-img'), { scale: 1.22 }, { scale: 1.07, duration: 1.55, ease: 'expo.out' }, 3.95);

			const stepStart = 4.4;
			const stepGap = 0.55;
			tcSteps.forEach((step, i) => {
				const at = stepStart + i * stepGap;
				tl.from(step, { autoAlpha: 0, duration: 0.25, ease: 'none' }, at);
				if (i > 0) {
					tl.to(tcSteps[i - 1], { opacity: 0.42, duration: 0.3, ease: 'none' }, at);
				}
			});

			const stepsEnd = stepStart + tcSteps.length * stepGap;
			tl.fromTo(
				tcProgress,
				{ scaleX: 0 },
				{ scaleX: 1, duration: stepsEnd - stepStart + 0.3, ease: 'none' },
				stepStart
			);
			tl.to(tcSteps[tcSteps.length - 1], { opacity: 0.42, duration: 0.3, ease: 'none' }, stepsEnd + 0.3)
				.from(tcDone, { autoAlpha: 0, scale: 0.4, duration: 0.35, ease: 'back.out(2.5)' }, stepsEnd + 0.3);

			// 信号存续期间：画面保持极缓的推进漂移（ease none）——静止的实录是死的
			tl.to(
				q('.footage-img'),
				{ scale: 1.03, xPercent: -0.9, duration: stepsEnd + 1.3 - 5.5, ease: 'none' },
				5.5
			);

			// —— 第四幕：它办成了。结果落地，前情整体退后半步，焦点收到这一句 ——
			const doneAt = stepsEnd + 1.3;
			tl.from(msgDone, { autoAlpha: 0, y: 56, duration: 0.85, ease: 'power3.out' }, doneAt)
				.to([msgYou, msgAck, tool], { opacity: 0.38, duration: 0.85 }, doneAt)
				/* 信号收线：缝隙反向收拢回中缝（power3.in，先缓后疾像掐断传输），
				   画面同时轻微下沉、末段变暗——退场与接通同一套语言 */
				.to(q('.footage'), { clipPath: 'inset(0% 50% 0% 50%)', duration: 0.9, ease: 'power3.in' }, doneAt)
				.to(q('.footage'), { autoAlpha: 0, duration: 0.45, ease: 'power1.in' }, doneAt + 0.5)
				.to(q('.footage-img'), { yPercent: 1.4, scale: 1.08, duration: 0.95, ease: 'power2.in' }, doneAt);

			// —— 注脚：全场静下来之后，最轻的一句 ——
			tl.from(note, { autoAlpha: 0, y: 20, duration: 0.6 }, doneAt + 1.3);

			// 收尾留一拍空滚动，让完成时刻在解钉前站稳
			tl.to({}, { duration: 1.1 }, doneAt + 2.1);
		}
	}
</script>
