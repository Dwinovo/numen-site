---
import { Image } from 'astro:assets';
import '../styles/global.css';
import hero from '../assets/hero.png';
import Nav from '../components/Nav.astro';
import Manifesto from '../components/Manifesto.astro';
import Demo from '../components/Demo.astro';
import Interlude from '../components/Interlude.astro';
import Vision from '../components/Vision.astro';
import Footer from '../components/Footer.astro';
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Numen — 言出法随</title>
		<meta
			name="description"
			content="Numen 让大模型走出聊天框，住进 Minecraft：一个会感知、会规划、会动手的 AI 同伴。你说出口，他便成真。"
		/>
	</head>
	<body>
		<Nav current="home" />
		<main id="page">
			<!-- ============ 首屏（钉住，被后续内容盖过） ============ -->
			<section class="hero">
				<!-- 大图相框：拉高、几乎铺满，标题从它上方穿过 -->
				<div class="hero-frame">
					<div class="hero-img-wrap absolute inset-0">
						<Image
							src={hero}
							alt="Minecraft 洞穴中仰望雪山与天光"
							class="hero-img h-full w-full object-cover"
							loading="eager"
							fetchpriority="high"
							widths={[1280, 1920, 2560]}
							sizes="100vw"
						/>
					</div>
					<!-- 副标题便签 + SCROLL 贴纸压在图的左下 / 右下角 -->
					<p class="hero-subtitle">你说出口，他便成真。</p>
					<p class="scroll-cue" aria-hidden="true">Scroll</p>
				</div>

				<!-- 巨字标题：叠在大图上半部，穿过相框 -->
				<h1 class="hero-title" aria-label="NUMEN">
					<span>N</span><span>U</span><span>M</span><span>E</span><span>N</span>
				</h1>
			</section>

			<!-- ============ 正文（滑过首屏） ============ -->
			<div class="content" id="content">
				<Manifesto />
				<Demo />
				<Interlude />
				<Vision />
				<Footer />
			</div>
		</main>
	</body>
</html>

<style>
	main {
		background-color: #fef9ed;
		color: #171310;
		font-family:
			'Source Han Sans SC', 'Noto Sans SC', 'PingFang SC',
			'Microsoft YaHei', 'Hiragino Sans GB', sans-serif;
	}

	/* ---------- 首屏 ---------- */
	.hero {
		position: relative;
		height: 100dvh;
		width: 100%;
		overflow: hidden;
		background-color: #fef9ed;
	}

	/* 大图：全屏铺满，NUMEN 巨字压在其上 */
	.hero-frame {
		position: absolute;
		inset: 0;
		overflow: hidden;
		background-color: #fef9ed;
	}

	/* 巨字标题：绝对定位压在大图上部 */
	.hero-title {
		position: absolute;
		z-index: 10;
		left: 3vw;
		right: 3vw;
		top: 10vh;
		display: flex;
		justify-content: space-between;
		font-weight: 900;
		/* 实测五字母总宽的不溢出上限为 23.69vw（随系统字体略有差异），留 1% 余量 */
		font-size: 23.5vw;
		line-height: 1;
		/* 米白巨字 + 墨黑硬阴影错位——压在暗色洞穴图上最跳，仍是粗野偏移阴影语言 */
		color: #fef9ed;
		user-select: none;
		text-shadow: 7px 7px 0 #171310;
	}

	/* 副标题：白字压在图左下角，墨黑硬阴影——与标题同款，无框 */
	.hero-subtitle {
		position: absolute;
		z-index: 5;
		left: clamp(1.2rem, 3vw, 3.5rem);
		bottom: clamp(1.2rem, 3vw, 3rem);
		margin: 0;
		color: #fef9ed;
		font-weight: 900;
		font-size: clamp(1.3rem, 3vw, 2.9rem);
		line-height: 1.25;
		text-shadow: 4px 4px 0 #171310;
		user-select: none;
	}

	/* SCROLL 贴纸：橙底 ink 边框硬阴影，压在图右下角，±2° 玩心旋转 */
	.scroll-cue {
		position: absolute;
		z-index: 5;
		right: clamp(1rem, 2.5vw, 2.5rem);
		bottom: clamp(1rem, 2.5vw, 2.5rem);
		margin: 0;
		color: #171310;
		font-family: 'Cascadia Mono', 'SF Mono', Consolas, ui-monospace, monospace;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.3em;
		text-transform: uppercase;
		background-color: #f5a623;
		border: 3px solid #171310;
		border-radius: 10px;
		padding: 0.55em 0.65em 0.55em 0.95em;
		box-shadow: 4px 4px 0 #171310;
		transform: rotate(2deg);
	}

	/* ---------- 正文容器（盖过钉住的首屏，全站统一米白底） ---------- */
	.content {
		position: relative;
		z-index: 10;
		background-color: #fef9ed;
	}
</style>

<script>
	import { gsap } from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	import Lenis from 'lenis';

	const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	if (!reduced) {
		gsap.registerPlugin(ScrollTrigger);

		// 平滑滚动：全站唯一的 Lenis 实例，与 ScrollTrigger 共用一个时钟
		const lenis = new Lenis({ lerp: 0.09 });
		lenis.on('scroll', ScrollTrigger.update);
		gsap.ticker.add((time) => lenis.raf(time * 1000));
		gsap.ticker.lagSmoothing(0);

		// 首屏：钉住，正文像幕布一样盖上来；同时相框内图推近、标题上浮淡出
		ScrollTrigger.create({
			trigger: '.hero',
			start: 'top top',
			end: 'bottom top',
			pin: true,
			pinSpacing: false,
		});
		gsap
			.timeline({
				scrollTrigger: { trigger: '#content', start: 'top bottom', end: 'top top', scrub: true },
			})
			.to('.hero-img', { scale: 1.15, ease: 'none' }, 0)
			.to('.hero-title', { yPercent: -30, autoAlpha: 0, ease: 'none' }, 0)
			.to('.hero-subtitle, .scroll-cue', { autoAlpha: 0, ease: 'none' }, 0);

		// 全站统一米白底：不再需要背景色随滚动渐变（morph 已删除）

		// 组件各自的 ScrollTrigger 注册完后，统一按文档顺序刷新一次，
		// 避免 pin 区块的先后顺序影响定位计算
		requestAnimationFrame(() => ScrollTrigger.refresh());
	}
</script>
