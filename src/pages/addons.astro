---
// Addons —— 生态目录页
// 定位：大厂 marketplace 式的功能页。首页负责表演，这里负责让人高效地找到东西。
// 结构：克制页头 → 独立粗野卡片 4 列网格（每页 12 = 4×3）→ 实体分页。
// 粗新野主义：每张卡 3px ink 边框 + 硬偏移阴影 + 10px 圆角，间距开阔；类型是微旋转的彩色贴纸 chip。
// 点击卡片弹出详情层：完整描述 + 相关链接（GitHub / CurseForge / Modrinth / 官网……任意多条）。
// 分页、详情层均为 client-side 增强：无 JS 时卡片直接是首链接的 <a>，全量可见可点。
import Subpage from '../layouts/Subpage.astro';

type EntryLink = { label: string; href: string };
type Entry = {
	type: '模组' | '引擎' | 'MCP' | 'Skill' | '工具';
	name: string;
	desc: string;
	author: string;
	// 第一条是主链接（卡片的无 JS 回退目标）；未来条目可自带 CurseForge / Modrinth 等
	links: EntryLink[];
};

// 条目按提交顺序追加即可——计数、分页、详情全部自动成立。
const entries: Entry[] = [
	{
		type: 'MCP',
		name: 'numen-qq-mcp',
		desc: '把游戏里的同伴绑上 QQ。人不在电脑前，私聊一句“把家里的小麦收了”，回来时箱子已经满了。',
		author: 'Dwinovo · 官方',
		links: [{ label: 'GitHub', href: 'https://github.com/Dwinovo/numen-qq-mcp' }],
	},
];

---

<Subpage title="能力 — Numen" description="Numen 生态的模组、Skill 与 MCP 目录。" current="addons">
	<div class="catalog" data-catalog>
		<header class="catalog-head">
			<h1 class="catalog-title">能力</h1>
			<p class="catalog-sub">生态里的模组、Skill 与 MCP。本站只做索引——链接指向 GitHub 或 CurseForge，作品永远属于作者。</p>
		</header>
		<section class="catalog-body" aria-label="生态目录">
			<div class="card-grid is-settling" data-grid>
				{
					entries.map((e, i) => (
						<a
							class="card"
							data-entry={JSON.stringify(e)}
							href={e.links[0].href}
							target="_blank"
							rel="noopener"
							style={`--i: ${i}`}
						>
							<span class="card-name">{e.name}</span>
							<span class="card-desc">{e.desc}</span>
							<span class="card-foot">
								<span class="card-author">{e.author}</span>
								<span class="card-cue" aria-hidden="true">
									<span class="cue-a">↗</span>
									<span class="cue-b">↗</span>
								</span>
							</span>
						</a>
					))
				}
			</div>

			<nav class="pager" data-pager hidden aria-label="分页">
				<button type="button" class="pager-btn" data-prev>← 上一页</button>
				<div class="pager-pages" data-pages></div>
				<button type="button" class="pager-btn" data-next>下一页 →</button>
			</nav>
		</section>

		<!-- 详情层：点击卡片弹出，展示完整描述与全部相关链接 -->
		<dialog class="detail" data-detail>
			<div class="detail-top">
				<span class="detail-type" data-d-type></span>
				<button type="button" class="detail-close" data-d-close aria-label="关闭">×</button>
			</div>
			<h2 class="detail-name" data-d-name></h2>
			<p class="detail-desc" data-d-desc></p>
			<p class="detail-author" data-d-author></p>
			<div class="detail-links" data-d-links></div>
		</dialog>
	</div>
</Subpage>

<script>
	const PAGE_SIZE = 12; // 4 列 × 3 行

	const catalog = document.querySelector<HTMLElement>('[data-catalog]');

	if (catalog) {
		const grid = catalog.querySelector<HTMLElement>('[data-grid]')!;
		const cards = [...grid.querySelectorAll<HTMLElement>('.card')];
		const pager = catalog.querySelector<HTMLElement>('[data-pager]')!;
		const pagesWrap = pager.querySelector<HTMLElement>('[data-pages]')!;
		const prevBtn = pager.querySelector<HTMLButtonElement>('[data-prev]')!;
		const nextBtn = pager.querySelector<HTMLButtonElement>('[data-next]')!;
		const reduced = window.matchMedia('(prefers-reduced-motion: reduce)');

		const pad = (n: number) => String(n).padStart(2, '0');

		let page = 1;

		// 页码序列：页数少全列出，页数多收敛为 1 … n-1 n n+1 … total
		function pageList(total: number, current: number): (number | '…')[] {
			if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
			const keep = new Set([1, total, current - 1, current, current + 1]);
			const list: (number | '…')[] = [];
			for (let i = 1; i <= total; i++) {
				if (keep.has(i)) list.push(i);
				else if (list[list.length - 1] !== '…') list.push('…');
			}
			return list;
		}

		function render(animate = true) {
			const totalPages = Math.max(1, Math.ceil(cards.length / PAGE_SIZE));
			if (page > totalPages) page = totalPages;

			const start = (page - 1) * PAGE_SIZE;
			const shown = cards.slice(start, start + PAGE_SIZE);
			cards.forEach((c) => c.classList.toggle('is-off', !shown.includes(c)));
			shown.forEach((c, i) => c.style.setProperty('--i', String(i)));

			prevBtn.disabled = page <= 1;
			nextBtn.disabled = page >= totalPages;
			pagesWrap.replaceChildren(
				...pageList(totalPages, page).map((p) => {
					if (p === '…') {
						const gap = document.createElement('span');
						gap.className = 'pager-gap';
						gap.textContent = '…';
						return gap;
					}
					const btn = document.createElement('button');
					btn.type = 'button';
					btn.className = 'pager-num';
					btn.textContent = pad(p);
					if (p === page) btn.setAttribute('aria-current', 'page');
					else
						btn.addEventListener('click', () => {
							page = p;
							render();
						});
					return btn;
				}),
			);

			if (animate && !reduced.matches) {
				grid.classList.remove('is-settling');
				void grid.offsetWidth; // 强制回流，重启一拍柔和的进场
				grid.classList.add('is-settling');
			}
		}

		prevBtn.addEventListener('click', () => {
			if (page > 1) {
				page--;
				render();
			}
		});
		nextBtn.addEventListener('click', () => {
			page++;
			render();
		});

		// —— 详情层：点击卡片弹出完整信息与全部相关链接 ——
		const detail = catalog.querySelector<HTMLDialogElement>('[data-detail]');
		if (detail) {
			const dType = detail.querySelector<HTMLElement>('[data-d-type]')!;
			const dName = detail.querySelector<HTMLElement>('[data-d-name]')!;
			const dDesc = detail.querySelector<HTMLElement>('[data-d-desc]')!;
			const dAuthor = detail.querySelector<HTMLElement>('[data-d-author]')!;
			const dLinks = detail.querySelector<HTMLElement>('[data-d-links]')!;

			const hostOf = (href: string) => {
				try {
					return new URL(href).hostname.replace(/^www\./, '');
				} catch {
					return href;
				}
			};

			const open = (card: HTMLElement) => {
				const e = JSON.parse(card.dataset.entry ?? '{}');
				dType.textContent = e.type ?? '';
				dName.textContent = e.name ?? '';
				dDesc.textContent = e.desc ?? '';
				dAuthor.textContent = e.author ?? '';
				dLinks.replaceChildren(
					...(e.links ?? []).map((l: { label: string; href: string }) => {
						const a = document.createElement('a');
						a.className = 'detail-link';
						a.href = l.href;
						a.target = '_blank';
						a.rel = 'noopener';
						a.innerHTML = `<span class="dl-label">${l.label}</span><span class="dl-host">${hostOf(l.href)}</span><span class="dl-cue" aria-hidden="true">↗</span>`;
						return a;
					}),
				);
				detail.showModal();
			};

			cards.forEach((card) => {
				card.addEventListener('click', (ev) => {
					ev.preventDefault();
					open(card);
				});
			});

			detail.querySelector('[data-d-close]')?.addEventListener('click', () => detail.close());
			// 点击面板外（backdrop）关闭
			detail.addEventListener('click', (ev) => {
				if (ev.target === detail) detail.close();
			});
		}

		// JS 就绪后才亮出分页——无 JS 时它不存在，卡片全量可见。
		pager.hidden = false;
		render(false);
	}
</script>

<style>
	/* ============ Numen 粗新野主义 v1 ——本页局部令牌 ============ */
	.catalog {
		--nb-ink: #171310;
		--nb-paper: #fef9ed;
		--nb-green: #86c15c;
		--nb-orange: #f5a623;
		--nb-blue: #5bb8e8;
		--nb-pink: #f39fc5;
		width: min(1720px, 90vw);
		margin-inline: auto;
	}

	/* ============ 页头：仍是克制的一行，但标题下压一笔草绿马克笔 ============ */
	.catalog-head {
		padding-top: clamp(7.5rem, 14vh, 9.5rem);
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: clamp(1.5rem, 4vw, 4rem);
		flex-wrap: wrap;
	}

	.catalog-title {
		position: relative;
		z-index: 0;
		font-family: var(--font-cjk);
		font-weight: 900;
		font-size: clamp(2.6rem, 5.5vw, 4.6rem);
		line-height: 1;
		letter-spacing: 0.04em;
		margin: 0;
	}

	/* 玩心一笔：微倾的草绿高亮垫在字底半截，像马克笔一挥 */
	.catalog-title::after {
		content: '';
		position: absolute;
		left: -0.12em;
		right: -0.12em;
		bottom: 0.05em;
		height: 0.34em;
		z-index: -1;
		background: var(--nb-green);
		border-radius: 3px;
		transform: rotate(-1.2deg);
	}

	.catalog-sub {
		margin: 0;
		font-size: clamp(0.88rem, 1.1vw, 0.98rem);
		line-height: 1.9;
		color: var(--faint);
	}

	.catalog-body {
		padding-top: clamp(1.8rem, 4vh, 2.8rem);
		padding-bottom: 0;
	}

	/* ============ 卡片网格：告别共享边框——独立卡片 + 开阔间距 ============
	   每张卡自带 3px ink 边框与硬偏移阴影，间距给足呼吸；4/3/2/1 列断点不变。 */
	.card-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: clamp(1.5rem, 2.2vw, 2rem);
		margin-top: clamp(2.5rem, 5vh, 3.5rem);
	}

	@media (min-width: 680px) {
		.card-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 1040px) {
		.card-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (min-width: 1360px) {
		.card-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}

	/* 卡片：3px 实线 + 5px 硬阴影 + 10px 圆角的实体面板。
	   hover 整卡抬起（-2,-2 / 阴影 7）、active 按下（+2,+2 / 阴影 2）——物理感就是反馈。 */
	.card {
		position: relative;
		display: flex;
		flex-direction: column;
		padding: clamp(1.6rem, 2vw, 2.2rem);
		background: var(--nb-paper);
		color: var(--nb-ink);
		border: 3px solid var(--nb-ink);
		border-radius: 10px;
		box-shadow: 5px 5px 0 var(--nb-ink);
		text-decoration: none;
		cursor: pointer;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease;
	}

	a.card:hover,
	a.card:focus-visible {
		transform: translate(-2px, -2px);
		box-shadow: 7px 7px 0 var(--nb-ink);
	}

	a.card:active {
		transform: translate(2px, 2px);
		box-shadow: 2px 2px 0 var(--nb-ink);
	}

	a.card:focus-visible {
		outline: 3px solid var(--nb-ink);
		outline-offset: 4px;
	}

	@media (min-width: 680px) {
		.card {
			min-height: clamp(280px, 30vh, 350px);
		}
	}

	.card.is-off {
		display: none;
	}


	/* 主角不变：mono 大标题，字号给足自信 */
	.card-name {
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: clamp(1.55rem, 1.8vw, 2.1rem);
		line-height: 1.22;
		overflow-wrap: anywhere;
	}

	/* 描述：常驻可见，钉在底部区——粗野主义信息不玩捉迷藏 */
	.card-desc {
		margin-top: auto;
		padding-top: clamp(1.8rem, 4vh, 2.6rem);
		font-size: clamp(0.92rem, 1vw, 1rem);
		line-height: 1.9;
		color: color-mix(in srgb, var(--nb-ink) 72%, transparent);
	}

	/* 底行：作者常驻靠左，右端粗箭头 */
	.card-foot {
		display: flex;
		align-items: baseline;
		gap: 1.2em;
		margin-top: clamp(1.2rem, 2.6vh, 1.8rem);
	}

	.card-author {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		color: color-mix(in srgb, var(--nb-ink) 55%, transparent);
	}

	/* 粗箭头：静息态半墨，hover 全墨并滑换——旧箭头出右上，新箭头自左下补位 */
	.card-cue {
		position: relative;
		width: 1.3em;
		height: 1.3em;
		margin-left: auto;
		align-self: center;
		overflow: hidden;
		font-size: 1.15rem;
		font-weight: 900;
		color: color-mix(in srgb, var(--nb-ink) 45%, transparent);
		transition: color 0.2s ease;
	}

	.card-cue span {
		position: absolute;
		inset: 0;
		display: grid;
		place-items: center;
		transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.cue-b {
		transform: translate(-130%, 130%);
	}

	a.card:hover .card-cue,
	a.card:focus-visible .card-cue {
		color: inherit;
	}

	a.card:hover .cue-a,
	a.card:focus-visible .cue-a {
		transform: translate(130%, -130%);
	}

	a.card:hover .cue-b,
	a.card:focus-visible .cue-b {
		transform: translate(0, 0);
	}

	/* 无 hover 设备：卡片不压最小高度，信息本就全量常驻 */
	@media (hover: none) {
		.card {
			min-height: 0;
		}
	}

	/* ============ 分页：全部实体按钮——边框 + 硬阴影 + 按压反馈 ============ */
	.pager {
		margin-top: clamp(3rem, 6vh, 4.5rem);
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1.2rem;
		flex-wrap: wrap;
	}

	.pager-btn {
		padding: 0.7em 1.2em;
		border: 3px solid var(--nb-ink);
		border-radius: 10px;
		background: var(--nb-paper);
		box-shadow: 5px 5px 0 var(--nb-ink);
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: 0.74rem;
		letter-spacing: 0.16em;
		color: var(--nb-ink);
		cursor: pointer;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease;
	}

	.pager-btn:hover:not(:disabled),
	.pager-btn:focus-visible:not(:disabled) {
		transform: translate(-2px, -2px);
		box-shadow: 7px 7px 0 var(--nb-ink);
	}

	.pager-btn:active:not(:disabled) {
		transform: translate(2px, 2px);
		box-shadow: 2px 2px 0 var(--nb-ink);
	}

	.pager-btn:disabled {
		opacity: 0.35;
		box-shadow: 2px 2px 0 var(--nb-ink);
		cursor: default;
	}

	.pager-pages {
		display: flex;
		align-items: center;
		gap: 0.8rem;
	}

	.pager :global(.pager-num) {
		min-width: 2.6em;
		padding: 0.55em 0.7em;
		border: 3px solid var(--nb-ink);
		border-radius: 10px;
		background: var(--nb-paper);
		box-shadow: 4px 4px 0 var(--nb-ink);
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: 0.74rem;
		letter-spacing: 0.1em;
		color: var(--nb-ink);
		cursor: pointer;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease;
	}

	.pager :global(.pager-num:hover:not([aria-current='page'])),
	.pager :global(.pager-num:focus-visible:not([aria-current='page'])) {
		transform: translate(-2px, -2px);
		box-shadow: 6px 6px 0 var(--nb-ink);
	}

	.pager :global(.pager-num:active:not([aria-current='page'])) {
		transform: translate(2px, 2px);
		box-shadow: 2px 2px 0 var(--nb-ink);
	}

	/* 当前页 = 被按下的草绿键：位移到底、阴影收紧，物理隐喻自洽 */
	.pager :global(.pager-num[aria-current='page']) {
		background: var(--nb-green);
		transform: translate(2px, 2px);
		box-shadow: 2px 2px 0 var(--nb-ink);
		cursor: default;
	}

	.pager :global(.pager-gap) {
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: 0.74rem;
		color: color-mix(in srgb, var(--nb-ink) 55%, transparent);
		padding: 0 0.3em;
	}

	/* ============ 详情层：粗边框 + 大硬阴影的实体面板 ============ */
	.detail {
		/* Tailwind preflight 清掉了 dialog 的默认 margin:auto，显式补回居中 */
		margin: auto;
		width: min(600px, 92vw);
		border: 3px solid var(--nb-ink, #171310);
		border-radius: 10px;
		background-color: #fef9ed;
		color: #171310;
		box-shadow: 10px 10px 0 #171310;
		padding: clamp(1.8rem, 3vw, 2.8rem);
		font-family: var(--font-cjk);
	}

	.detail::backdrop {
		background: rgba(23, 19, 16, 0.5);
	}

	@media (prefers-reduced-motion: no-preference) {
		.detail[open] {
			animation: detail-rise 0.3s cubic-bezier(0.22, 1, 0.36, 1);
		}

		.detail[open]::backdrop {
			animation: detail-fade 0.3s ease;
		}
	}

	@keyframes detail-rise {
		from {
			opacity: 0;
			transform: translateY(16px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes detail-fade {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	.detail-top {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: clamp(1.8rem, 3.5vh, 2.6rem);
	}

	/* 与卡片同语言：类型是一枚微旋转的草绿贴纸 */
	.detail-type {
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: 0.68rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		padding: 0.32em 0.8em;
		background: #86c15c;
		color: #171310;
		border: 3px solid #171310;
		border-radius: 10px;
		box-shadow: 3px 3px 0 #171310;
		transform: rotate(-2deg);
	}

	.detail-close {
		width: 2.4rem;
		height: 2.4rem;
		border: 3px solid #171310;
		border-radius: 10px;
		background: #fef9ed;
		color: #171310;
		box-shadow: 4px 4px 0 #171310;
		font-size: 1.15rem;
		font-weight: 700;
		line-height: 1;
		cursor: pointer;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease;
	}

	.detail-close:hover,
	.detail-close:focus-visible {
		transform: translate(-2px, -2px);
		box-shadow: 6px 6px 0 #171310;
	}

	.detail-close:active {
		transform: translate(2px, 2px);
		box-shadow: 2px 2px 0 #171310;
	}

	.detail-name {
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: clamp(1.5rem, 2.4vw, 2rem);
		line-height: 1.25;
		margin: 0;
		overflow-wrap: anywhere;
	}

	.detail-desc {
		margin: 1.2rem 0 0;
		font-size: clamp(0.98rem, 1.15vw, 1.08rem);
		line-height: 2;
		color: color-mix(in srgb, #171310 72%, transparent);
	}

	.detail-author {
		margin: 1.4rem 0 0;
		font-family: var(--font-mono);
		font-size: 0.74rem;
		letter-spacing: 0.14em;
		color: color-mix(in srgb, #171310 55%, transparent);
