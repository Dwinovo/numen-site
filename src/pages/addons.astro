---
// Addons —— 生态目录页
// 定位：大厂 marketplace 式的功能页。首页负责表演，这里负责让人高效地找到东西。
// 结构：克制页头 → 独立粗野卡片 4 列网格（每页 12 = 4×3）→ 实体分页。
// 粗新野主义：每张卡 3px ink 边框 + 硬偏移阴影 + 10px 圆角，间距开阔；类型是微旋转的彩色贴纸 chip。
// 点击卡片弹出详情层：完整描述 + 相关链接（GitHub / CurseForge / Modrinth / 官网……任意多条）。
// 分页、详情层均为 client-side 增强：无 JS 时卡片直接是首链接的 <a>，全量可见可点。
import Subpage from '../layouts/Subpage.astro';
import { getCollection } from 'astro:content';

// 数据来自 src/content/addons/*.json（内容集合）——纯静态，构建期读入，无数据库、无接口。
// 新增/修改附属走 GitHub PR，合并到 main 即由 EdgeOne Pages 自动构建部署。
// 卡片点开弹窗看详情：详情数据构建期内联进页面，点击本地取用，无需请求。
const collection = await getCollection('addons');
const entries = collection
	.map((e) => ({
		id: e.id,
		type: e.data.type ?? '',
		name: e.data.name,
		desc: e.data.description,
		author: e.data.author,
		links: e.data.links,
		order: e.data.order ?? 999,
	}))
	.sort((a, b) => a.order - b.order || a.name.localeCompare(b.name));

// 详情层数据：id → 完整字段，序列化进页面供弹窗读取
const detailMap = Object.fromEntries(
	entries.map((e) => [e.id, { type: e.type, name: e.name, description: e.desc, author: e.author, links: e.links }]),
);
---

<Subpage title="附属 — Numen" description="Numen 生态的模组、Skill 与 MCP 目录。" current="addons">
	<div class="catalog" data-catalog>
		<header class="catalog-head">
			<h1 class="catalog-title">附属</h1>
			<p class="catalog-sub">生态里的模组、Skill 与 MCP。本站只做索引——链接指向 GitHub 或 CurseForge，作品永远属于作者。</p>
		</header>
		<section class="catalog-body" aria-label="生态目录">
			<div class="card-grid is-settling" data-grid>
				{
					entries.map((e, i) => (
						<a class="card" href={`/a/${e.id}`} style={`--i: ${i}`}>
							{e.type && <span class="card-type">{e.type}</span>}
							<span class="card-name">{e.name}</span>
							<span class="card-desc">{e.desc}</span>
							<span class="card-foot">
								<span class="card-author">
									<span class="card-ava card-ava--fb">{(e.author || 'N').slice(0, 1).toUpperCase()}</span>
									<span class="card-author-name">{e.author}</span>
								</span>
								<span class="card-cue" aria-hidden="true">
									<span class="cue-a">→</span>
									<span class="cue-b">→</span>
								</span>
							</span>
						</a>
					))
				}
			</div>

			<nav class="pager" data-pager hidden aria-label="分页">
				<button type="button" class="pager-btn" data-prev>← 上一页</button>
				<div class="pager-pages" data-pages></div>
				<button type="button" class="pager-btn" data-next>下一页 →</button>
			</nav>
		</section>

		<dialog class="dsheet" data-detail>
			<div class="dsheet-inner" data-detail-body></div>
		</dialog>

		<script type="application/json" data-addons set:html={JSON.stringify(detailMap)}></script>
	</div>
</Subpage>

<script>
	import { resolvePlatform } from '../lib/links';

	const PAGE_SIZE = 12; // 4 列 × 3 行

	const catalog = document.querySelector<HTMLElement>('[data-catalog]');

	if (catalog) {
		const grid = catalog.querySelector<HTMLElement>('[data-grid]')!;
		const cards = [...grid.querySelectorAll<HTMLElement>('.card')];
		const pager = catalog.querySelector<HTMLElement>('[data-pager]')!;
		const pagesWrap = pager.querySelector<HTMLElement>('[data-pages]')!;
		const prevBtn = pager.querySelector<HTMLButtonElement>('[data-prev]')!;
		const nextBtn = pager.querySelector<HTMLButtonElement>('[data-next]')!;
		const reduced = window.matchMedia('(prefers-reduced-motion: reduce)');

		const pad = (n: number) => String(n).padStart(2, '0');

		let page = 1;

		// 页码序列：页数少全列出，页数多收敛为 1 … n-1 n n+1 … total
		function pageList(total: number, current: number): (number | '…')[] {
			if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
			const keep = new Set([1, total, current - 1, current, current + 1]);
			const list: (number | '…')[] = [];
			for (let i = 1; i <= total; i++) {
				if (keep.has(i)) list.push(i);
				else if (list[list.length - 1] !== '…') list.push('…');
			}
			return list;
		}

		function render(animate = true) {
			const totalPages = Math.max(1, Math.ceil(cards.length / PAGE_SIZE));
			if (page > totalPages) page = totalPages;

			const start = (page - 1) * PAGE_SIZE;
			const shown = cards.slice(start, start + PAGE_SIZE);
			cards.forEach((c) => c.classList.toggle('is-off', !shown.includes(c)));
			shown.forEach((c, i) => c.style.setProperty('--i', String(i)));

			prevBtn.disabled = page <= 1;
			nextBtn.disabled = page >= totalPages;
			pagesWrap.replaceChildren(
				...pageList(totalPages, page).map((p) => {
					if (p === '…') {
						const gap = document.createElement('span');
						gap.className = 'pager-gap';
						gap.textContent = '…';
						return gap;
					}
					const btn = document.createElement('button');
					btn.type = 'button';
					btn.className = 'pager-num';
					btn.textContent = pad(p);
					if (p === page) btn.setAttribute('aria-current', 'page');
					else
						btn.addEventListener('click', () => {
							page = p;
							render();
						});
					return btn;
				}),
			);

			if (animate && !reduced.matches) {
				grid.classList.remove('is-settling');
				void grid.offsetWidth; // 强制回流，重启一拍柔和的进场
				grid.classList.add('is-settling');
			}
		}

		prevBtn.addEventListener('click', () => {
			if (page > 1) {
				page--;
				render();
			}
		});
		nextBtn.addEventListener('click', () => {
			page++;
			render();
		});

		// —— 详情弹窗：点卡片本地取用构建期内联的数据，不跳页、不请求 ——
		const sheet = catalog.querySelector<HTMLDialogElement>('[data-detail]');
		const body = sheet?.querySelector<HTMLElement>('[data-detail-body]') ?? null;
		let DATA: Record<string, any> = {};
		try {
			DATA = JSON.parse(document.querySelector<HTMLElement>('[data-addons]')?.textContent || '{}');
		} catch {
			DATA = {};
		}

		const esc = (s: unknown) =>
			String(s ?? '').replace(/[&<>"']/g, (m) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[m]!));

		const linkHtml = (l: any) => {
			const p = resolvePlatform(l.href);
			const label = l.label && String(l.label).trim() ? l.label : p.label;
			return (
				`<a class="plink" href="${esc(l.href)}" target="_blank" rel="noopener" style="--brand:${p.color}">` +
				`<span class="plink-chip"></span><span class="plink-label">${esc(label)}</span>` +
				`<span class="plink-arrow" aria-hidden="true">↗</span></a>`
			);
		};

		const renderDetail = (d: any) => {
			const links = (d.links || []).length ? `<div class="ds-links">${(d.links || []).map(linkHtml).join('')}</div>` : '';
			return (
				`<button class="ds-close" data-close type="button" aria-label="关闭">×</button>` +
				(d.type ? `<span class="ds-type">${esc(d.type)}</span>` : '') +
				`<h2 class="ds-name">${esc(d.name)}</h2>` +
				`<p class="ds-desc">${esc(d.description)}</p>` +
				`<span class="ds-author"><span class="ds-ava ds-ava--fb">${esc((d.author || 'N').slice(0, 1).toUpperCase())}</span>` +
				`<span class="ds-author-name">${esc(d.author)}</span></span>` +
				links
			);
		};

		const openSheet = (id: string) => {
			if (!sheet || !body) return;
			const d = DATA[id];
			if (!d) return;
			body.innerHTML = renderDetail(d);
			body.querySelector('[data-close]')?.addEventListener('click', () => sheet.close());
			if (!sheet.open) sheet.showModal();
		};

		if (sheet && body) {
			cards.forEach((card) => {
				card.addEventListener('click', (ev) => {
					ev.preventDefault();
					const id = (card.getAttribute('href') || '').split('/a/')[1];
					if (id) openSheet(id);
				});
			});
			sheet.addEventListener('click', (ev) => {
				if (ev.target === sheet) sheet.close();
			});
			const wantId = new URLSearchParams(location.search).get('a');
			if (wantId) openSheet(wantId);
		}

		// JS 就绪后才亮出分页——无 JS 时它不存在，卡片全量可见。
		pager.hidden = false;
		render(false);
	}
</script>

<style>
	/* ============ Numen 粗新野主义 v1 ——本页局部令牌 ============ */
	.catalog {
		--nb-ink: #171310;
		--nb-paper: #fef9ed;
		--nb-green: #86c15c;
		--nb-orange: #f5a623;
		--nb-blue: #5bb8e8;
		--nb-pink: #f39fc5;
		width: min(1720px, 90vw);
		margin-inline: auto;
	}

	/* ============ 页头：仍是克制的一行，但标题下压一笔草绿马克笔 ============ */
	.catalog-head {
		padding-top: clamp(7.5rem, 14vh, 9.5rem);
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: clamp(1.5rem, 4vw, 4rem);
		flex-wrap: wrap;
	}

	.catalog-title {
		position: relative;
		z-index: 0;
		font-family: var(--font-cjk);
		font-weight: 900;
		font-size: clamp(2.6rem, 5.5vw, 4.6rem);
		line-height: 1;
		letter-spacing: 0.04em;
		margin: 0;
	}

	/* 玩心一笔：微倾的草绿高亮垫在字底半截，像马克笔一挥 */
	.catalog-title::after {
		content: '';
		position: absolute;
		left: -0.12em;
		right: -0.12em;
		bottom: 0.05em;
		height: 0.34em;
		z-index: -1;
		background: var(--nb-green);
		border-radius: 3px;
		transform: rotate(-1.2deg);
	}

	.catalog-sub {
		margin: 0;
		font-size: clamp(0.88rem, 1.1vw, 0.98rem);
		line-height: 1.9;
		color: var(--faint);
	}

	.catalog-body {
		padding-top: clamp(1.8rem, 4vh, 2.8rem);
		padding-bottom: 0;
	}

	/* ============ 卡片网格：告别共享边框——独立卡片 + 开阔间距 ============
	   每张卡自带 3px ink 边框与硬偏移阴影，间距给足呼吸；4/3/2/1 列断点不变。 */
	.card-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: clamp(1.5rem, 2.2vw, 2rem);
		margin-top: clamp(2.5rem, 5vh, 3.5rem);
	}

	@media (min-width: 680px) {
		.card-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 1040px) {
		.card-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (min-width: 1360px) {
		.card-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}

	/* 卡片：3px 实线 + 5px 硬阴影 + 10px 圆角的实体面板。
	   hover 整卡抬起（-2,-2 / 阴影 7）、active 按下（+2,+2 / 阴影 2）——物理感就是反馈。 */
	.card {
		position: relative;
		display: flex;
		flex-direction: column;
		padding: clamp(1.6rem, 2vw, 2.2rem);
		background: var(--nb-paper);
		color: var(--nb-ink);
		border: 3px solid var(--nb-ink);
		border-radius: 10px;
		box-shadow: 5px 5px 0 var(--nb-ink);
		text-decoration: none;
		cursor: pointer;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease;
	}

	a.card:hover,
	a.card:focus-visible {
		transform: translate(-2px, -2px);
		box-shadow: 7px 7px 0 var(--nb-ink);
	}

	a.card:active {
		transform: translate(2px, 2px);
		box-shadow: 2px 2px 0 var(--nb-ink);
	}

	a.card:focus-visible {
		outline: 3px solid var(--nb-ink);
		outline-offset: 4px;
	}

	@media (min-width: 680px) {
		.card {
			min-height: clamp(280px, 30vh, 350px);
		}
	}

	.card.is-off {
		display: none;
	}


	/* 主角不变：mono 大标题，字号给足自信 */
	.card-name {
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: clamp(1.55rem, 1.8vw, 2.1rem);
		line-height: 1.22;
		overflow-wrap: anywhere;
	}

	/* 描述：紧贴标题下方 */
	.card-desc {
		margin-top: clamp(0.8rem, 1.6vh, 1.1rem);
		font-size: clamp(0.92rem, 1vw, 1rem);
		line-height: 1.9;
		color: color-mix(in srgb, var(--nb-ink) 72%, transparent);
	}

	/* 底行：作者钉在卡片底部，右端粗箭头 */
	.card-foot {
		display: flex;
		align-items: center;
		gap: 1.2em;
		margin-top: auto;
		padding-top: clamp(1.4rem, 3vh, 2rem);
	}

	.card-author {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		min-width: 0;
	}

	.card-ava {
		flex-shrink: 0;
		width: 32px;
		height: 32px;
		object-fit: cover;
		display: block;
		border: 2.5px solid var(--nb-ink);
		border-radius: 8px;
		box-shadow: 2px 2px 0 var(--nb-ink);
		background: #fff;
	}

	.card-ava--fb {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-family: var(--font-mono);
		font-weight: 900;
		font-size: 0.9rem;
		color: var(--nb-ink);
		background: var(--nb-green);
	}

	.card-author-name {
		font-family: var(--font-mono);
		font-size: 0.9rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		color: color-mix(in srgb, var(--nb-ink) 68%, transparent);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	/* 类型 chip（有才显示） */
	.card-type {
		align-self: flex-start;
		font-family: var(--font-mono);
		font-size: 0.66rem;
		font-weight: 700;
		color: var(--nb-ink);
		background: var(--nb-green);
		border: 2px solid var(--nb-ink);
		border-radius: 6px;
		padding: 0.18em 0.5em;
		margin-bottom: 0.7rem;
		transform: rotate(-1.5deg);
	}

	/* 粗箭头：静息态半墨，hover 全墨并滑换——旧箭头出右上，新箭头自左下补位 */
	.card-cue {
		position: relative;
		width: 1.3em;
		height: 1.3em;
		margin-left: auto;
		align-self: center;
		overflow: hidden;
		font-size: 1.15rem;
		font-weight: 900;
		color: color-mix(in srgb, var(--nb-ink) 45%, transparent);
		transition: color 0.2s ease;
	}

	.card-cue span {
		position: absolute;
		inset: 0;
		display: grid;
		place-items: center;
		transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.cue-b {
		transform: translate(-130%, 130%);
	}

	a.card:hover .card-cue,
	a.card:focus-visible .card-cue {
		color: inherit;
	}

	a.card:hover .cue-a,
	a.card:focus-visible .cue-a {
		transform: translate(130%, -130%);
	}

	a.card:hover .cue-b,
	a.card:focus-visible .cue-b {
		transform: translate(0, 0);
	}

	/* 无 hover 设备：卡片不压最小高度，信息本就全量常驻 */
	@media (hover: none) {
		.card {
			min-height: 0;
		}
	}

	/* ============ 分页：全部实体按钮——边框 + 硬阴影 + 按压反馈 ============ */
	.pager {
		margin-top: clamp(3rem, 6vh, 4.5rem);
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1.2rem;
		flex-wrap: wrap;
	}

	.pager-btn {
		padding: 0.7em 1.2em;
		border: 3px solid var(--nb-ink);
		border-radius: 10px;
		background: var(--nb-paper);
		box-shadow: 5px 5px 0 var(--nb-ink);
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: 0.74rem;
		letter-spacing: 0.16em;
		color: var(--nb-ink);
		cursor: pointer;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease;
	}

	.pager-btn:hover:not(:disabled),
	.pager-btn:focus-visible:not(:disabled) {
		transform: translate(-2px, -2px);
		box-shadow: 7px 7px 0 var(--nb-ink);
	}

	.pager-btn:active:not(:disabled) {
		transform: translate(2px, 2px);
		box-shadow: 2px 2px 0 var(--nb-ink);
	}

	.pager-btn:disabled {
		opacity: 0.35;
		box-shadow: 2px 2px 0 var(--nb-ink);
		cursor: default;
	}

	.pager-pages {
		display: flex;
		align-items: center;
		gap: 0.8rem;
	}

	.pager :global(.pager-num) {
		min-width: 2.6em;
		padding: 0.55em 0.7em;
		border: 3px solid var(--nb-ink);
		border-radius: 10px;
		background: var(--nb-paper);
		box-shadow: 4px 4px 0 var(--nb-ink);
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: 0.74rem;
		letter-spacing: 0.1em;
		color: var(--nb-ink);
		cursor: pointer;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease;
	}

	.pager :global(.pager-num:hover:not([aria-current='page'])),
	.pager :global(.pager-num:focus-visible:not([aria-current='page'])) {
		transform: translate(-2px, -2px);
		box-shadow: 6px 6px 0 var(--nb-ink);
	}

	.pager :global(.pager-num:active:not([aria-current='page'])) {
		transform: translate(2px, 2px);
		box-shadow: 2px 2px 0 var(--nb-ink);
	}

	/* 当前页 = 被按下的草绿键：位移到底、阴影收紧，物理隐喻自洽 */
	.pager :global(.pager-num[aria-current='page']) {
		background: var(--nb-green);
		transform: translate(2px, 2px);
		box-shadow: 2px 2px 0 var(--nb-ink);
		cursor: default;
	}

	.pager :global(.pager-gap) {
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: 0.74rem;
		color: color-mix(in srgb, var(--nb-ink) 55%, transparent);
		padding: 0 0.3em;
	}

	/* ============ 详情层：粗边框 + 大硬阴影的实体面板 ============ */
	.dsheet {
		/* Tailwind preflight 清掉了 dialog 的默认 margin:auto，显式补回居中 */
		margin: auto;
		width: min(640px, 92vw);
		max-height: 86vh;
		overflow-y: auto;
		border: 3px solid var(--nb-ink, #171310);
		border-radius: 12px;
		background-color: #fef9ed;
		color: #171310;
		box-shadow: 10px 10px 0 #171310;
		padding: clamp(1.6rem, 3vw, 2.4rem);
		font-family: var(--font-cjk);
	}

	.dsheet::backdrop {
		background: rgba(23, 19, 16, 0.5);
	}

	@media (prefers-reduced-motion: no-preference) {
		.dsheet[open] {
			animation: detail-rise 0.3s cubic-bezier(0.22, 1, 0.36, 1);
		}

		.dsheet[open]::backdrop {
			animation: detail-fade 0.3s ease;
		}
	}

	@keyframes detail-rise {
		from {
			opacity: 0;
			transform: translateY(16px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes detail-fade {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	/* ==== 弹窗内容（JS 以 innerHTML 注入，故须 :global 命中）==== */
	.dsheet {
		position: relative;
