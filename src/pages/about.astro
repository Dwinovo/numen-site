---
// 关于 —— 编辑级名片：近单色（墨黑 + 米白，草绿仅一处），巨型名字排版为主角，
// 头像相框（硬阴影）为唯一实体签名物，其余靠留白与对齐。粗野主义的骨，编辑级的静。
// 事实取自作者抖音简介与 dwinovo.cn/about，不编造。
import Subpage from '../layouts/Subpage.astro';
import { Image } from 'astro:assets';
import avatar from '../assets/dwinovo-avatar.jpg';

const focus = ['Agent 开发', 'MC 模组开发', '全栈工程', '隐蔽智能体通信'];
const contact = [
	{ k: '微信', v: 'Dwinovo', href: null },
	{ k: '邮箱', v: '2328703107@qq.com', href: 'mailto:2328703107@qq.com' },
	{ k: 'GitHub', v: 'github.com/Dwinovo ↗', href: 'https://github.com/Dwinovo' },
];
---

<Subpage
	title="关于我 — Dwinovo"
	description="Dwinovo —— 北邮在读，Agent 开发 / MC 模组开发 / 全栈。Numen 的创造者。"
	current="about"
>
	<article class="card">
		<!-- ============ 名头 ============ -->
		<header class="mast">
			<div class="mast-lede">
				<p class="eyebrow">关于 · ABOUT</p>
				<h1 class="name">Dwinovo</h1>
				<p class="role">北邮在读 &nbsp;·&nbsp; 网络空间安全</p>
			</div>
			<figure class="portrait">
				<Image src={avatar} alt="Dwinovo 的头像" widths={[240, 480]} sizes="220px" />
			</figure>
		</header>

		<!-- ============ 陈述 ============ -->
		<section class="statement">
			<p class="lead">
				我给大模型一副<span class="mark">身体</span>——让它走出聊天框，住进一个能真实感知、真实行动的世界。
			</p>
			<p class="sub">
				这就是 <a href="https://github.com/Dwinovo" target="_blank" rel="noopener">Numen</a>，由我一个人独立创造并维护。技术不该只是"硬核"，更要产生真实世界的影响。
			</p>
		</section>

		<!-- ============ 索引：专注 / 联系 ============ -->
		<footer class="index">
			<div class="idx-col">
				<p class="idx-label">专注 / FOCUS</p>
				<ul class="idx-list">
					{focus.map((f) => <li>{f}</li>)}
				</ul>
			</div>
			<div class="idx-col">
				<p class="idx-label">联系 / CONTACT</p>
				<dl class="idx-contact">
					{
						contact.map((c) => (
							<div class="idx-crow">
								<dt>{c.k}</dt>
								<dd>
									{c.href ? (
										<a href={c.href} target={c.href.startsWith('http') ? '_blank' : undefined} rel="noopener">
											{c.v}
										</a>
									) : (
										<span>{c.v}</span>
									)}
								</dd>
							</div>
						))
					}
				</dl>
			</div>
		</footer>
	</article>
</Subpage>

<style>
	.card {
		width: min(1080px, 90vw);
		margin-inline: auto;
		padding: clamp(5.5rem, 11vh, 7.5rem) 0 clamp(3.5rem, 7vh, 5rem);
	}

	/* ============ 名头 ============ */
	.mast {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: center;
		gap: clamp(1.5rem, 5vw, 4rem);
	}

	.eyebrow {
		margin: 0 0 clamp(1rem, 2.5vh, 1.6rem);
		font-family: var(--font-mono);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.36em;
		text-transform: uppercase;
		color: var(--faint);
	}

	.name {
		margin: 0;
		font-weight: 900;
		font-size: clamp(3.6rem, 13vw, 9rem);
		line-height: 0.88;
		letter-spacing: -0.045em;
		color: var(--ink);
	}

	.role {
		margin: clamp(1.1rem, 2.5vh, 1.6rem) 0 0;
		font-family: var(--font-mono);
		font-size: clamp(0.82rem, 1.3vw, 1rem);
		letter-spacing: 0.08em;
		color: var(--muted);
	}

	/* 唯一实体签名物 —— 头像相框 + 硬阴影 */
	.portrait {
		margin: 0;
		flex-shrink: 0;
		width: clamp(120px, 19vw, 210px);
		aspect-ratio: 1;
		border: 3px solid var(--ink);
		border-radius: 16px;
		box-shadow: 9px 9px 0 var(--ink);
		overflow: hidden;
		background-color: #fff;
		transform: rotate(-2deg);
	}

	.portrait :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	/* ============ 陈述 ============ */
	.statement {
		margin-top: clamp(2.5rem, 6vh, 4.5rem);
		max-width: min(54rem, 100%);
	}

	.lead {
		margin: 0;
		font-weight: 800;
		font-size: clamp(1.5rem, 3vw, 2.3rem);
		line-height: 1.5;
		letter-spacing: -0.01em;
		color: var(--ink);
	}

	/* 全站唯一一处彩色：草绿标记笔划线 */
	.mark {
		box-shadow: inset 0 -0.32em 0 var(--grass);
	}

	.sub {
		margin: clamp(1.4rem, 3vh, 2rem) 0 0;
		max-width: 30em;
		font-size: clamp(1rem, 1.4vw, 1.2rem);
		line-height: 1.9;
		color: var(--muted);
	}

	.sub a {
		color: var(--ink);
		font-weight: 700;
		text-decoration: underline;
		text-underline-offset: 4px;
		text-decoration-thickness: 2px;
		text-decoration-color: var(--ink);
	}

	.sub a:hover { text-decoration-color: var(--grass); }

	/* ============ 索引 ============ */
	.index {
		margin-top: clamp(2.5rem, 6vh, 4rem);
		border-top: 3px solid var(--ink);
		padding-top: clamp(1.8rem, 4vh, 2.6rem);
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(2rem, 5vw, 4rem);
	}

	.idx-label {
		margin: 0 0 clamp(1rem, 2.5vh, 1.5rem);
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: var(--faint);
	}

	.idx-list {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.idx-list li {
		font-size: clamp(1rem, 1.4vw, 1.18rem);
		font-weight: 700;
		line-height: 1.9;
		color: var(--ink);
	}

	.idx-contact {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
	}

	.idx-crow {
		display: flex;
		align-items: baseline;
		gap: 1.1rem;
	}

	.idx-crow dt {
		flex-shrink: 0;
		width: 3.4em;
		font-family: var(--font-mono);
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		color: var(--faint);
	}

	.idx-crow dd {
		margin: 0;
		min-width: 0;
		font-family: var(--font-mono);
		font-size: clamp(0.9rem, 1.2vw, 1rem);
		font-weight: 700;
		color: var(--ink);
		word-break: break-all;
	}

	.idx-crow a {
		color: var(--ink);
		text-decoration: underline;
		text-underline-offset: 4px;
		text-decoration-thickness: 2px;
		text-decoration-color: var(--hairline);
		transition: text-decoration-color 0.15s ease;
	}

	.idx-crow a:hover { text-decoration-color: var(--grass); }

	/* ============ 响应式 ============ */
	@media (max-width: 680px) {
		.mast {
			grid-template-columns: 1fr;
			gap: 1.8rem;
		}
		.portrait {
			order: -1;
			width: clamp(104px, 30vw, 140px);
		}
		.index {
			grid-template-columns: 1fr;
			gap: 2.2rem;
		}
	}
</style>
