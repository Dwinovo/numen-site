const toolIface = `public interface NumenTool {
    // 模型看到的工具名，snake_case
    String name();

    // 给模型的描述 —— 决定模型能否正确选中此工具的最大杠杆
    String description();

    // 参数的 JSON Schema（OpenAI 工具参数方言）
    Map<String, Object> parameterSchema();

    // 执行一次调用：现在干、稍后干、客户端干、服务端干、丢给外部服务干都行，
    // 结果就绪时通过 ToolCall.complete(...) 回报
    void invoke(ToolCall call);
}`;

const toolExample = `// 示例（基于真实契约合成，非仓库原文）：一个把消息发回 QQ 的出站工具
public final class SendQqMessageTool implements NumenTool {
    public String name() { return "send_qq_message"; }

    public String description() {
        return "Send a QQ message back to the requester.";
    }

    public Map<String, Object> parameterSchema() {
        return Map.of(
            "type", "object",
            "properties", Map.of(
                "message", Map.of("type", "string"),
                "user_id", Map.of("type", "integer")
            ),
            "required", List.of("message")
        );
    }

    public void invoke(ToolCall call) {
        JsonObject args = call.args();      // 解析后的参数（非法 JSON 抛异常）
        // ... 干活：通过 websocket 发出去 ...
        call.complete(TaskResult.ok("sent").toJson());   // 唯一的"完成"动词
    }
}`;

const registerCode = `// 在模组初始化时注册一次（重名抛 IllegalStateException，不静默替换）
ToolRegistry.register(new SendQqMessageTool());`;

