<script>
	// scroll-spy：正文滚动时高亮侧栏当前章
	const links = new Map<string, HTMLElement>();
	document.querySelectorAll<HTMLElement>('[data-toc]').forEach((el) => {
		links.set(el.dataset.toc!, el);
	});

	const setActive = (id: string) => {
		links.forEach((el, key) => el.classList.toggle('is-active', key === id));
	};

	const sections = [...document.querySelectorAll<HTMLElement>('.doc-sec')];
	if (sections.length && links.size) {
		const obs = new IntersectionObserver(
			(entries) => {
				// 取当前视口内最靠上的可见章节
				const visible = entries
					.filter((e) => e.isIntersecting)
					.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
				if (visible[0]) setActive(visible[0].target.id);
			},
			{ rootMargin: '-20% 0px -70% 0px', threshold: 0 }
		);
		sections.forEach((s) => obs.observe(s));
		setActive(sections[0].id);
	}
</script>
